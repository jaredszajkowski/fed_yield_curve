# The core pipeline needs no credentials — the Federal Reserve yield-curve
# data (feds200628.csv) is publicly downloaded by src/pull_fed_yield_curve.py.
#
# The optional CRSP Treasury pull (doit pull:crsp_treasury → CRSP_TFZ_INFO.parquet,
# used for GSW Figure 1) queries WRDS and requires a WRDS account. Set your
# username below and store the password in ~/.pgpass (see the wrds package docs).
WRDS_USERNAME=your_wrds_username
